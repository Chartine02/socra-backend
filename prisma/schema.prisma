generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────

enum StudyMode {
  SOCRATIC
  QUIZ
  FLASHCARD
}

enum BloomLevel {
  REMEMBER
  UNDERSTAND
  APPLY
  ANALYSE
  EVALUATE
  CREATE
}

enum MasteryState {
  MASTERED
  SHAKY
  FORGOTTEN
}

enum ConfidenceRating {
  GUESSING
  UNSURE
  CONFIDENT
}

enum SelfRating {
  FORGOT
  HARD
  GOOD
  EASY
}

enum ProcessingStatus {
  PROCESSING
  READY
  ERROR
}

enum UserRole {
  STUDENT
  INSTRUCTOR
}

enum NotificationType {
  QUIZ_PERFORMANCE
  ASSIGNMENT_PERFORMANCE
  STUDY_SUGGESTION
  WEEKLY_DIGEST
  SYSTEM
}

// ─── MODELS ───────────────────────────────────────────────────────────────

model User {
  id                String          @id @default(uuid())
  email             String          @unique
  passwordHash      String?
  fullName          String
  university        String
  role              UserRole        @default(STUDENT)
  isEmailVerified   Boolean         @default(false)
  emailVerifyToken  String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  canvasUserId      String?
  canvasCourseId    String?
  emailNotifications Boolean        @default(true)
  studyStreak       Int             @default(0)
  lastStudiedAt     DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  documents         Document[]
  studySessions     StudySession[]
  flashcards        Flashcard[]
  quizResponses     QuizResponse[]
  dialogueTurns     DialogueTurn[]
  canvasTokens      CanvasToken[]
  canvasCourses     CanvasCourse[]
  notifications     Notification[]
  canvasQuizSubmissions     CanvasQuizSubmission[]
  canvasAssignmentSubmissions CanvasAssignmentSubmission[]

  @@map("users")
}

model Document {
  id               String            @id @default(uuid())
  userId           String
  fileName         String
  fileSize         Int
  mimeType         String
  storageKey       String
  summary          String?           // AI-generated study notes/summary
  processingStatus ProcessingStatus  @default(PROCESSING)
  processingError  String?
  overallMastery   Float             @default(0)
  lastStudiedAt    DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledgeUnits   KnowledgeUnit[]
  studySessions    StudySession[]
  flashcards       Flashcard[]
  quizQuestions    QuizQuestion[]
  canvasContentItems CanvasContentItem[]

  @@map("documents")
}

model KnowledgeUnit {
  id                String        @id @default(uuid())
  documentId        String
  topic             String
  concept           String
  sourceExcerpt     String
  bloomLevel        BloomLevel    @default(REMEMBER)
  masteryState      MasteryState  @default(FORGOTTEN)
  masteryPercentage Float         @default(0)
  lastReviewedAt    DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  document          Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  flashcards        Flashcard[]
  quizQuestions     QuizQuestion[]

  @@map("knowledge_units")
}

model StudySession {
  id              String        @id @default(uuid())
  userId          String
  documentId      String
  mode            StudyMode
  startedAt       DateTime      @default(now())
  endedAt         DateTime?
  itemsCompleted  Int           @default(0)
  finalBloomLevel BloomLevel?
  scorePercent    Float?
  createdAt       DateTime      @default(now())

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  document        Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  quizResponses   QuizResponse[]
  dialogueTurns   DialogueTurn[]

  @@map("study_sessions")
}

model QuizQuestion {
  id              String            @id @default(uuid())
  documentId      String
  knowledgeUnitId String
  questionText    String
  options         Json
  correctIndex    Int
  bloomLevel      BloomLevel
  explanation     String
  sourceExcerpt   String
  createdAt       DateTime          @default(now())

  document        Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  knowledgeUnit   KnowledgeUnit     @relation(fields: [knowledgeUnitId], references: [id], onDelete: Cascade)
  responses       QuizResponse[]

  @@map("quiz_questions")
}

model QuizResponse {
  id               String           @id @default(uuid())
  userId           String
  sessionId        String
  questionId       String
  selectedIndex    Int
  isCorrect        Boolean
  confidenceRating ConfidenceRating
  timeTakenSeconds Int?
  createdAt        DateTime         @default(now())

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  session          StudySession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question         QuizQuestion     @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("quiz_responses")
}

model Flashcard {
  id              String       @id @default(uuid())
  userId          String
  documentId      String
  knowledgeUnitId String
  front           String
  back            String
  sourceExcerpt   String
  interval        Int          @default(1)
  easeFactor      Float        @default(2.5)
  repetitions     Int          @default(0)
  nextReviewAt    DateTime     @default(now())
  masteryState    MasteryState @default(FORGOTTEN)
  lastRating      SelfRating?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  document        Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  knowledgeUnit   KnowledgeUnit @relation(fields: [knowledgeUnitId], references: [id], onDelete: Cascade)
  reviewHistory   FlashcardReview[]

  @@map("flashcards")
}

model FlashcardReview {
  id           String     @id @default(uuid())
  flashcardId  String
  rating       SelfRating
  previousInterval    Int
  newInterval         Int
  previousEaseFactor  Float
  newEaseFactor       Float
  reviewedAt   DateTime   @default(now())

  flashcard    Flashcard  @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@map("flashcard_reviews")
}

model DialogueTurn {
  id          String     @id @default(uuid())
  userId      String
  sessionId   String
  role        String
  content     String
  bloomLevel  BloomLevel
  createdAt   DateTime   @default(now())

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  session     StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("dialogue_turns")
}

// ─── CANVAS / LTI INTEGRATION ─────────────────────────────────────────────

model LtiPlatform {
  id              String   @id @default(uuid())
  issuer          String   @unique    // e.g. https://canvas.instructure.com
  clientId        String               // LTI Developer Key client ID
  deploymentId    String?
  authEndpoint    String               // OIDC auth URL
  tokenEndpoint   String               // OAuth2 token URL
  jwksEndpoint    String               // Platform JWKS URL for key validation
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("lti_platforms")
}

model LtiState {
  id        String   @id @default(uuid())
  state     String   @unique
  nonce     String
  payload   Json?    // stores login_hint, lti_message_hint, etc.
  consumed  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("lti_states")
}

model CanvasToken {
  id            String   @id @default(uuid())
  userId        String
  canvasBaseUrl String   // e.g. https://alu.instructure.com
  accessToken   String   // encrypted
  refreshToken  String   // encrypted
  expiresAt     DateTime
  scopes        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, canvasBaseUrl])
  @@map("canvas_tokens")
}

model CanvasCourse {
  id              String   @id @default(uuid())
  userId          String
  canvasCourseId  String
  canvasBaseUrl   String
  courseName      String
  courseCode       String?
  lastSyncedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItems    CanvasContentItem[]
  quizSubmissions       CanvasQuizSubmission[]
  assignmentSubmissions CanvasAssignmentSubmission[]

  @@unique([userId, canvasCourseId, canvasBaseUrl])
  @@map("canvas_courses")
}

model CanvasContentItem {
  id              String   @id @default(uuid())
  canvasCourseId  String   // FK to CanvasCourse
  canvasItemId    String   // Canvas's own ID for the item
  itemType        String   // "page", "file", "module"
  title           String
  contentUrl      String?  // URL to fetch content
  htmlContent     String?  // For pages: raw HTML body
  textContent     String?  // Extracted plain text
  fileSize        Int?
  lastModifiedAt  DateTime?
  documentId      String?  // Link to SOCRA Document if processed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  course          CanvasCourse @relation(fields: [canvasCourseId], references: [id], onDelete: Cascade)
  document        Document?    @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@unique([canvasCourseId, canvasItemId, itemType])
  @@map("canvas_content_items")
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType
  title       String
  message     String
  data        Json?
  isRead      Boolean          @default(false)
  emailSent   Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── CANVAS PERFORMANCE TRACKING ──────────────────────────────────────────

model CanvasQuizSubmission {
  id                  String   @id @default(uuid())
  userId              String
  canvasCourseId      String
  canvasQuizId        String
  canvasSubmissionId  String
  quizTitle           String
  score               Float?
  pointsPossible      Float?
  scorePercent        Float?
  attemptNumber       Int      @default(1)
  submittedAt         DateTime?
  questionResults     Json?
  weakTopics          Json?
  suggestions         Json?
  analyzed            Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  course              CanvasCourse @relation(fields: [canvasCourseId], references: [id], onDelete: Cascade)

  @@unique([userId, canvasQuizId, canvasSubmissionId])
  @@map("canvas_quiz_submissions")
}

model CanvasAssignmentSubmission {
  id                    String   @id @default(uuid())
  userId                String
  canvasCourseId        String
  canvasAssignmentId    String
  canvasSubmissionId    String
  assignmentTitle       String
  score                 Float?
  pointsPossible        Float?
  scorePercent          Float?
  grade                 String?
  submittedAt           DateTime?
  gradedAt              DateTime?
  submissionComments    Json?
  suggestions           Json?
  analyzed              Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  course                CanvasCourse @relation(fields: [canvasCourseId], references: [id], onDelete: Cascade)

  @@unique([userId, canvasAssignmentId, canvasSubmissionId])
  @@map("canvas_assignment_submissions")
}

# =========================================================================
# SOCRA — Environment Variables (example)
# Copy to .env.local and fill in. NEVER commit .env.local.
# =========================================================================

# ---- Database ----
DATABASE_URL=

# ---- Auth ----
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ---- Frontend ----
FRONTEND_URL=http://localhost:5173

# ---- AI Service ----
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_API_KEY=

# ---- Supabase Storage ----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=socra-documents

# ---- LLM Providers (free tiers) ----
GEMINI_API_KEY=                     # https://aistudio.google.com/apikey
GROQ_API_KEY=                       # https://console.groq.com/keys

# ---- Observability (optional in dev) ----
SENTRY_DSN=
POSTHOG_KEY=

# ---- LTI 1.3 (Canvas) — only required once LTI module lands (Week 2) ----
LTI_PLATFORM_URL=https://canvas.alueducation.com
LTI_CLIENT_ID=
LTI_DEPLOYMENT_ID=
LTI_KEYSET_URL=
LTI_ENCRYPTION_KEY=

# ---- Worker (FastAPI) — required from Week 3 ----
WORKER_BASE_URL=http://localhost:8000
WORKER_INTERNAL_TOKEN=              # shared HMAC between web <-> worker

# PostgreSQL connection string
DATABASE_URL=""

# JWT signing secret — use a long random string in production
JWT_SECRET=""

# JWT token expiry duration
JWT_EXPIRES_IN="7d"

# Base URL of the external FastAPI AI pipeline service
AI_SERVICE_URL=""

# API key for authenticating with the AI service
AI_SERVICE_API_KEY=""

# Canvas LTI 1.3 client ID (for institutional integration)
CANVAS_LTI_CLIENT_ID=""

# Canvas instance URL (e.g. https://alu.instructure.com)
CANVAS_LTI_PLATFORM_URL=""

# Canvas LTI deployment ID
CANVAS_LTI_DEPLOYMENT_ID=""

# Frontend URL for CORS
CLIENT_URL="http://localhost:3000"

# Port the server listens on
PORT=8000
